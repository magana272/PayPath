# Blank = docker compose runs a bundled MongoDB container and uses it.
# Set to your own database (e.g. an Atlas mongodb+srv:// URI) and the
# bundled Mongo is skipped.
MONGODB_URI=

# Signing key for auth tokens
JWT_SECRET=change-me

# Allowed CORS origin
FRONTEND_URL=http://localhost:3000

# Listen address (default :8000)
# HTTP_ADDR=:8000

# development / production
# ENV=development

# Optional: enables /api/ai/* endpoints
OPENAI_API_KEY=

# Optional: Stripe billing
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_PRICE_ID_YEARLY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PORTAL_CONFIG_ID=
